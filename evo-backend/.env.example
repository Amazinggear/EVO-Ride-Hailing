# ================================================
# EVO Backend — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git
# ================================================

# App
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database (PostgreSQL with PostGIS)
# Get from: Neon.tech or Supabase free tier
DATABASE_URL=postgresql://username:password@host:5432/evo_db?sslmode=require

# Redis (Upstash — free tier)
# Get from: upstash.com
REDIS_URL=rediss://username:password@host:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-different-from-access-secret-minimum-32

# Firebase Admin SDK
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# OneSignal Push Notifications
# Get from: onesignal.com → App Settings → Keys & IDs
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# Google Maps (for server-side validation)
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OpenChargeMap (for charging stations sync)
# Get from: openchargemap.org/site/develop/api
OPENCHARGE_MAP_API_KEY=your-ocm-api-key

# PayTabs (Payment Gateway)
# Get from: merchant.paytabs.com after setting up merchant account
PAYTABS_SERVER_KEY=your-paytabs-server-key
PAYTABS_PROFILE_ID=your-paytabs-profile-id
PAYTABS_REGION=JO

# Cloudflare R2 (Document Storage)
# Get from: cloudflare.com → R2
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret
CLOUDFLARE_R2_BUCKET_NAME=evo-documents
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# CORS — allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://evo-admin.vercel.app
